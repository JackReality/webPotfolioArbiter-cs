@page "/access-denied"
@* Affichée soit par Routes.razor (rôle insuffisant), soit par redirection HTTP
   (AccessDeniedPath du cookie) quand un user connecté n'a pas le bon rôle. *@
@inject IStringLocalizer<SharedResource> L

<div class="pa-page">
    <MudText Typo="Typo.h3" GutterBottom="true">@L["AccessDenied.Title"]</MudText>
    <MudText Class="mb-6" Style="opacity:.85;">@L["AccessDenied.Body"]</MudText>
    <MudButton Href="/catalog" Variant="Variant.Filled" Color="Color.Primary">@L["AccessDenied.Cta"]</MudButton>
</div>
