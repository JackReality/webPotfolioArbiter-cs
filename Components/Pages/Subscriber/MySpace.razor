@page "/myspace"
@attribute [Authorize(Roles = "subscriber,client,admin")]
@using System.Security.Claims
@inject IStringLocalizer<SharedResource> L
@inject AuthenticationStateProvider AuthStateProvider
@inject UserTrainingService UserTrainingService
@inject TrainingService TrainingService

<PageTitle>Mon Espace</PageTitle>

<div class="pa-page" style="max-width:700px;">
    <MudText Typo="Typo.h3" GutterBottom="true">Mon Espace</MudText>

    @* ===== Ressources ===== *@
    <MudText Typo="Typo.h5" Class="mt-6 mb-2">Ressources</MudText>
    <MudPaper Class="pa-5 mb-6 d-flex align-center justify-space-between" Elevation="0" Style="background:#1a1a1a;">
        <div>
            <MudText Typo="Typo.h6" GutterBottom="false">Fichier de suivi</MudText>
            <MudText Style="opacity:.6; font-size:.9rem;">Google Sheets · Gestion de portefeuille</MudText>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.TableChart"
                   Href="/download">
            Accéder
        </MudButton>
    </MudPaper>

    @* ===== Formations ===== *@
    <MudText Typo="Typo.h5" Class="mb-2">Mes formations</MudText>

    @if (!_loaded)
    {
        <MudProgressLinear Color="Color.Info" Indeterminate="true" />
    }
    else if (_trainings.Count == 0)
    {
        <MudPaper Class="pa-6 text-center" Elevation="0" Style="background:#1a1a1a;">
            <MudIcon Icon="@Icons.Material.Filled.School"
                     Style="font-size:3rem; opacity:.3;"
                     Class="mb-3" />
            <MudText Typo="Typo.h6" GutterBottom="true">Aucune formation pour l'instant</MudText>
            <MudText Class="mb-4" Style="opacity:.6;">
                Découvrez nos formations et commencez à investir avec méthode.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.ArrowForward"
                       Href="/catalog">
                Voir le catalogue
            </MudButton>
        </MudPaper>
    }
    else
    {
        @foreach (var training in _trainings)
        {
            <MudPaper Class="pa-5 mb-3 d-flex align-center justify-space-between" Elevation="0" Style="background:#1a1a1a;">
                <div>
                    <MudText Typo="Typo.h6" GutterBottom="false">@training.Title</MudText>
                    <MudText Style="opacity:.5; font-size:.85rem;">@training.Code</MudText>
                </div>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           Href="@(string.IsNullOrWhiteSpace(training.PageUrl) ? "/myspace" : $"/{training.PageUrl.TrimStart('/')}")">
                    Accéder
                </MudButton>
            </MudPaper>
        }

        <div class="mt-4 text-center">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.AddShoppingCart"
                       Href="/catalog">
                Ajouter une formation
            </MudButton>
        </div>
    }
</div>

@code {
    private bool _loaded;
    private List<Models.Training> _trainings = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var idClaim = user.FindFirst(ClaimTypes.NameIdentifier);
        if (idClaim != null && ulong.TryParse(idClaim.Value, out var userId))
        {
            var achats = await UserTrainingService.GetByUserAsync(userId);
            var codes = achats.Select(a => a.TrainingCode);
            _trainings = await TrainingService.GetByCodesAsync(codes);
        }

        _loaded = true;
    }
}
