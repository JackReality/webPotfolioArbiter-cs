@page "/reset"
@inject IStringLocalizer<SharedResource> L
@inject UserService UserService
@inject TokenService TokenService
@inject EmailService EmailService
@inject NavigationManager Nav
@using DotNetEnv

<PageTitle>@L["Reset.Title"]</PageTitle>

<div class="pa-page" style="max-width:460px;">
    <MudPaper Class="pa-6" Elevation="0" Style="background:#141414;">
        <MudText Typo="Typo.h4" GutterBottom="true">@L["Reset.Title"]</MudText>
        <MudText Class="mb-4" Style="opacity:.8;">@L["Reset.Subtitle"]</MudText>

        @if (_success)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">@L["Reset.SuccessMessage"]</MudAlert>
            <div class="mt-4">
                <MudLink Href="/login">@L["Common.BackToLogin"]</MudLink>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
            }

            <form @onsubmit="RequestResetAsync" @onsubmit:preventDefault>
                <label class="pa-field-label">@L["Auth.Email"]</label>
                <input class="pa-input" type="email" @bind="_email" required autocomplete="email" />

                <button class="pa-submit" type="submit" Disabled="@_isLoading">
                    @(_isLoading ? L["Common.Sending"] : L["Reset.Submit"])
                </button>
            </form>

            <div class="mt-4">
                <MudLink Href="/login">@L["Common.Back"]</MudLink>
            </div>
        }
    </MudPaper>
</div>

@code {
    private string _email = string.Empty;
    private string? _error;
    private bool _success;
    private bool _isLoading;

    private async Task RequestResetAsync()
    {
        _error = null;
        _success = false;
        _isLoading = true;

        if (string.IsNullOrWhiteSpace(_email))
        {
            _error = L["ChangePassword.FillAll"];
            _isLoading = false;
            return;
        }

        try
        {
            // On cherche l'utilisateur par email
            var user = await UserService.GetByEmailAsync(_email);
            
            // Pour des raisons de sécurité, on affiche le même message de succès 
            // même si l'email n'existe pas, pour éviter l'énumération des comptes.
            if (user != null)
            {
                // Générer un token de récupération (valide 1 heure)
                var token = await TokenService.GenererJetonsAsync(user.Id, "recovery", dureeHeures: 1);
                
                // Construire le lien de réinitialisation à partir de BASE_URL dans .env
                var baseUrl = Env.GetString("BASE_URL", "http://localhost:5252").TrimEnd('/');
                var resetLink = $"{baseUrl}/reset-password?token={token}";
                
                // Corps de l'email (simple HTML)
                var htmlBody = $@"
                    <h2>Réinitialisation de votre mot de passe</h2>
                    <p>Bonjour {user.DisplayName},</p>
                    <p>Vous avez demandé à réinitialiser votre mot de passe pour votre compte Portfolio Arbiter.</p>
                    <p>Cliquez sur le lien ci-dessous pour choisir un nouveau mot de passe (ce lien est valide pendant 1 heure) :</p>
                    <p><a href=""{resetLink}"" style=""background-color: #1976d2; color: white; padding: 10px 20px; text-decoration: none; border-radius: 4px;"">Réinitialiser mon mot de passe</a></p>
                    <p>Si vous n'avez pas fait cette demande, vous pouvez ignorer cet e-mail en toute sécurité.</p>
                    <p>Cordialement,<br>L'équipe Portfolio Arbiter</p>
                ";

                // Envoi de l'email
                await EmailService.EnvoyerEmailAsync(user.Email, "Réinitialisation de votre mot de passe", htmlBody);
            }

            _success = true;
        }
        catch (Exception ex)
        {
            // TEMPORAIRE : Afficher la vraie erreur pour le débogage SMTP
            _error = $"Erreur SMTP : {ex.Message}";
            // TODO: Intégrer ici le mailErrorSend() global mentionné dans QWEN.md
        }
        finally
        {
            _isLoading = false;
        }
    }
}
