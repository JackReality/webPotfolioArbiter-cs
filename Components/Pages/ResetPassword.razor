@page "/reset-password"
@inject IStringLocalizer<SharedResource> L
@inject UserService UserService
@inject TokenService TokenService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>@L["ChangePassword.Title"]</PageTitle>

<div class="pa-page" style="max-width:460px;">
    <MudPaper Class="pa-6" Elevation="0" Style="background:#141414;">
        <MudText Typo="Typo.h4" GutterBottom="true">@L["ChangePassword.Title"]</MudText>
        <MudText Class="mb-4" Style="opacity:.8;">@L["ChangePassword.RecoverySubtitle"]</MudText>

        @if (_success)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">@L["ChangePassword.Saved"]</MudAlert>
            <div class="mt-4">
                <MudLink Href="/login">@L["Common.BackToLogin"]</MudLink>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
            }

            <MudForm OnSubmit="SubmitAsync">
                <MudTextField @bind-Value="_newPassword" Label="@L["ChangePassword.NewPassword"]" InputType="InputType.Password" Required="true" Margin="Margin.Dense" Class="mb-3" />
                <MudTextField @bind-Value="_confirmPassword" Label="@L["ChangePassword.ConfirmPassword"]" InputType="InputType.Password" Required="true" Margin="Margin.Dense" Class="mb-3" />

                <MudButton ButtonType="ButtonType.Button" OnClick="SubmitAsync" Disabled="@(_userId == null)" FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">
                    @L["ChangePassword.Submit"]
                </MudButton>
            </MudForm>

            <div class="mt-4">
                <MudLink Href="@(_isRecoveryMode ? "/login" : "/profile")">@L["Common.Back"]</MudLink>
            </div>
        }
    </MudPaper>
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private bool _isRecoveryMode => !string.IsNullOrEmpty(Token);
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private string? _error;
    private bool _success;
    private ulong? _userId;

    protected override async Task OnInitializedAsync()
    {
        if (_isRecoveryMode)
        {
            // Mode récupération par e-mail : le token définit l'utilisateur
            _userId = await TokenService.GetUserIdFromTokenAsync(Token!, "recovery");
            if (_userId == null)
            {
                _error = L["ChangePassword.InvalidOrExpiredToken"];
            }
        }
        else
        {
            // Mode profil : l'utilisateur doit être connecté
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var idClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (idClaim != null && ulong.TryParse(idClaim.Value, out var id))
            {
                _userId = id;
            }
            else
            {
                Nav.NavigateTo("/login");
            }
        }
    }

    private async Task SubmitAsync()
    {
        if (_userId == null)
        {
            _error = L["ChangePassword.InvalidOrExpiredToken"];
            return;
        }

        _error = null;
        _success = false;

        if (string.IsNullOrWhiteSpace(_newPassword) || string.IsNullOrWhiteSpace(_confirmPassword))
        {
            _error = L["ChangePassword.FillAll"];
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            _error = L["ChangePassword.Mismatch"];
            return;
        }

        if (_newPassword.Length < 6)
        {
            _error = L["ChangePassword.TooShort"];
            return;
        }

        var changed = await UserService.ChangerMotDePasseAsync(_userId.Value, _newPassword);
        if (!changed)
        {
            _error = L["ChangePassword.Error"];
            return;
        }

        if (_isRecoveryMode && Token != null)
        {
            await TokenService.SupprimerJetonAsync(Token);
        }

        _success = true;
        _newPassword = string.Empty;
        _confirmPassword = string.Empty;
    }
}