@page "/reset-password"
@inject IStringLocalizer<SharedResource> L
@inject UserService UserService
@inject EmailService EmailService
@inject EmailTemplateService TemplateService
@inject CodeService CodeService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@using System.Text.RegularExpressions

<PageTitle>@L["ChangePassword.Title"]</PageTitle>

<div class="pa-page" style="max-width:460px;">
    <MudPaper Class="pa-6" Elevation="0" Style="background:#141414;">
        <MudText Typo="Typo.h4" GutterBottom="true">@L["ChangePassword.Title"]</MudText>

        @if (_success)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">@L["ChangePassword.Saved"]</MudAlert>
            <div class="mt-4">
                <MudLink Href="/profile">@L["Common.Back"]</MudLink>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
            }

            @if (!_codeSent)
            {
                <MudText Class="mb-4" Style="opacity:.8;">@L["ChangePassword.ProfileSubtitle"]</MudText>
                <button class="pa-submit" @onclick="SendCodeAsync" disabled="@_isLoading">
                    @(_isLoading ? L["Common.Sending"] : L["Code.GetCode"])
                </button>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="mb-4" Style="opacity:.8;">
                    @L["Register.CodeSentTo"] @_userEmail
                </MudText>

                <form @onsubmit="SubmitAsync" @onsubmit:preventDefault>
                    <label class="pa-field-label">@L["Code.Placeholder"]</label>
                    <input class="pa-input" type="text" @bind="_codeInput" maxlength="6" autocomplete="one-time-code" />

                    <label class="pa-field-label">@L["ChangePassword.NewPassword"]</label>
                    <input class="pa-input" type="password" @bind="_newPassword" autocomplete="new-password" />

                    <label class="pa-field-label">@L["ChangePassword.ConfirmPassword"]</label>
                    <input class="pa-input" type="password" @bind="_confirmPassword" autocomplete="new-password" />

                    <button class="pa-submit" type="submit" disabled="@_isLoading">
                        @(_isLoading ? L["Common.Sending"] : L["ChangePassword.Submit"])
                    </button>

                    <div class="mt-2">
                        <MudLink @onclick="SendCodeAsync" Style="cursor:pointer;">@L["Code.Resend"]</MudLink>
                    </div>
                </form>
            }

            <div class="mt-4">
                <MudLink Href="/profile">@L["Common.Back"]</MudLink>
            </div>
        }
    </MudPaper>
</div>

@code {
    private string _codeInput = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private string? _error;
    private bool _success;
    private bool _isLoading;
    private bool _codeSent;
    private string? _userEmail;
    private ulong? _userId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var idClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        var emailClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email);

        if (idClaim != null && ulong.TryParse(idClaim.Value, out var id))
        {
            _userId = id;
            _userEmail = emailClaim?.Value;
        }
        else
        {
            Nav.NavigateTo("/login");
        }

        StateHasChanged();
    }

    private async Task SendCodeAsync()
    {
        if (_userId is null || string.IsNullOrWhiteSpace(_userEmail)) return;
        _error = null;
        _isLoading = true;

        try
        {
            var code = CodeService.GenerateCode(_userEmail);
            var user = await UserService.GetByIdAsync(_userId.Value);
            var language = user?.Language ?? "fr";
            var template = await TemplateService.GetAsync("recovery", language);

            string subject;
            string htmlBody;
            if (template != null)
            {
                subject = template.Subject;
                htmlBody = Regex.Replace(template.Html, @"\{\{\s*\.?Code\s*\}\}", code);
            }
            else
            {
                subject = "Votre code de modification";
                htmlBody = $"<p>Votre code : <strong>{code}</strong> (valable 20 minutes).</p>";
            }

            await EmailService.EnvoyerEmailAsync(_userEmail, subject, htmlBody);
            _codeSent = true;
            _codeInput = string.Empty;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SubmitAsync()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_newPassword) || string.IsNullOrWhiteSpace(_confirmPassword))
        {
            _error = L["ChangePassword.FillAll"];
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            _error = L["ChangePassword.Mismatch"];
            return;
        }

        try
        {
            CodeService.CheckCode(_userEmail!, _codeInput);
        }
        catch (BusinessException ex)
        {
            _error = L[ex.Key];
            return;
        }

        try
        {
            await UserService.ChangerMotDePasseAsync(_userId!.Value, _newPassword);
            _success = true;
        }
        catch (BusinessException ex)
        {
            _error = L[ex.Key];
        }
    }
}
