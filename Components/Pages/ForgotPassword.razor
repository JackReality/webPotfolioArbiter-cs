@page "/forgot-password"
@inject IStringLocalizer<SharedResource> L
@inject UserService UserService
@inject EmailService EmailService
@inject EmailTemplateService TemplateService
@inject CodeService CodeService
@using System.Text.RegularExpressions

<PageTitle>@L["ForgotPassword.Title"]</PageTitle>

<div class="pa-page" style="max-width:460px;">
    <MudPaper Class="pa-6" Elevation="0" Style="background:#141414;">
        <MudText Typo="Typo.h4" GutterBottom="true">@L["ForgotPassword.Title"]</MudText>

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
        }

        @if (_success)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">@L["ChangePassword.Saved"]</MudAlert>
            <div class="mt-4">
                <MudLink Href="/login">@L["Common.BackToLogin"]</MudLink>
            </div>
        }
        else
        {
            <form @onsubmit="SubmitAsync" @onsubmit:preventDefault>
                <label class="pa-field-label">@L["Auth.Email"]</label>
                <input class="pa-input" type="email" @bind="_email" required autocomplete="email" disabled="@_codeSent" />

                @if (!_codeSent)
                {
                    <button class="pa-submit" type="submit" disabled="@_isLoading">
                        @(_isLoading ? L["Common.Sending"] : L["ForgotPassword.Submit"])
                    </button>
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mt-4 mb-2" Style="opacity:.8;">
                        @L["Register.CodeSentTo"] @_email
                    </MudText>

                    <label class="pa-field-label">@L["Code.Placeholder"]</label>
                    <input class="pa-input" type="text" @bind="_codeInput" maxlength="6" autocomplete="one-time-code" />

                    <label class="pa-field-label">@L["ChangePassword.NewPassword"]</label>
                    <input class="pa-input" type="password" @bind="_newPassword" autocomplete="new-password" />

                    <label class="pa-field-label">@L["ChangePassword.ConfirmPassword"]</label>
                    <input class="pa-input" type="password" @bind="_confirmPassword" autocomplete="new-password" />

                    <button class="pa-submit" type="submit" disabled="@_isLoading">
                        @(_isLoading ? L["Common.Sending"] : L["ChangePassword.Submit"])
                    </button>

                    <div class="mt-2">
                        <MudLink @onclick="ResendAsync" Style="cursor:pointer;">@L["Code.Resend"]</MudLink>
                    </div>
                }
            </form>

            <div class="mt-4">
                <MudLink Href="/login">@L["Common.Back"]</MudLink>
            </div>
        }
    </MudPaper>
</div>

@code {
    private string _email = string.Empty;
    private string _codeInput = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private string? _error;
    private bool _success;
    private bool _isLoading;
    private bool _codeSent;
    private string? _userEmail;

    private async Task SubmitAsync()
    {
        _error = null;
        _isLoading = true;

        try
        {
            if (!_codeSent)
                await SendCodeAsync();
            else
                await ValidateAndResetAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SendCodeAsync()
    {
        if (string.IsNullOrWhiteSpace(_email))
        {
            _error = L["ChangePassword.FillAll"];
            return;
        }

        var user = await UserService.GetByEmailAsync(_email);
        if (user != null)
        {
            _userEmail = user.Email;
            var code = CodeService.GenerateCode(_email);
            var language = string.IsNullOrWhiteSpace(user.Language) ? "fr" : user.Language;
            await EnvoyerCodeAsync(_email, code, language);
        }

        _codeSent = true;
    }

    private async Task ValidateAndResetAsync()
    {
        if (string.IsNullOrWhiteSpace(_newPassword) || string.IsNullOrWhiteSpace(_confirmPassword))
        {
            _error = L["ChangePassword.FillAll"];
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            _error = L["ChangePassword.Mismatch"];
            return;
        }

        try
        {
            CodeService.CheckCode(_email, _codeInput);
        }
        catch (BusinessException ex)
        {
            _error = L[ex.Key];
            return;
        }

        var user = await UserService.GetByEmailAsync(_email);
        if (user is null) { _success = true; return; }

        try
        {
            await UserService.ChangerMotDePasseAsync(user.Id, _newPassword);
            _success = true;
        }
        catch (BusinessException ex)
        {
            _error = L[ex.Key];
        }
    }

    private async Task ResendAsync()
    {
        _error = null;
        _codeInput = string.Empty;
        var user = await UserService.GetByEmailAsync(_email);
        if (user != null)
        {
            var code = CodeService.GenerateCode(_email);
            var language = string.IsNullOrWhiteSpace(user.Language) ? "fr" : user.Language;
            await EnvoyerCodeAsync(_email, code, language);
        }
    }

    private async Task EnvoyerCodeAsync(string email, string code, string language)
    {
        var template = await TemplateService.GetAsync("recovery", language);

        string subject;
        string htmlBody;
        if (template != null)
        {
            subject = template.Subject;
            htmlBody = Regex.Replace(template.Html, @"\{\{\s*\.?Code\s*\}\}", code);
        }
        else
        {
            subject = "Votre code de réinitialisation";
            htmlBody = $"<p>Votre code : <strong>{code}</strong> (valable 20 minutes).</p>";
        }

        await EmailService.EnvoyerEmailAsync(email, subject, htmlBody);
    }
}
