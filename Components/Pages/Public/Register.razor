@page "/register"
@inject IStringLocalizer<SharedResource> L
@inject UserService UserService
@inject EmailService EmailService
@inject EmailTemplateService TemplateService
@inject CodeService CodeService
@inject NavigationManager Nav
@using DotNetEnv
@using System.Text.RegularExpressions

<PageTitle>@L["Register.Title"]</PageTitle>

<div class="pa-page" style="max-width:460px;">
    <MudPaper Class="pa-6" Elevation="0" Style="background:#141414;">
        <MudText Typo="Typo.h4" GutterBottom="true">@L["Register.Title"]</MudText>
        <MudText Class="mb-4" Style="opacity:.8;">@L["Register.Subtitle"]</MudText>

        @if (_success)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">@L["Register.SuccessMessage"]</MudAlert>
            <div class="mt-4">
                <MudLink Href="/login">@L["Common.BackToLogin"]</MudLink>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
            }

            <form @onsubmit="SubmitAsync" @onsubmit:preventDefault>
                <label class="pa-field-label">@L["Profile.DisplayName"]</label>
                <input class="pa-input" type="text" @bind="_displayName" required autocomplete="name" disabled="@_codeSent" />

                <label class="pa-field-label">@L["Auth.Email"]</label>
                <input class="pa-input" type="email" @bind="_email" required autocomplete="email" disabled="@_codeSent" />

                <label class="pa-field-label">@L["Auth.Password"]</label>
                <input class="pa-input" type="password" @bind="_password" required autocomplete="new-password" disabled="@_codeSent" />

                <label class="pa-field-label">@L["Register.PasswordConfirm"]</label>
                <input class="pa-input" type="password" @bind="_passwordConfirm" required autocomplete="new-password" disabled="@_codeSent" />

                @if (!_codeSent)
                {
                    <button class="pa-submit" type="submit" disabled="@_isLoading">
                        @(_isLoading ? L["Common.Sending"] : L["Code.GetCode"])
                    </button>
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mt-4 mb-2" Style="opacity:.8;">
                        @L["Register.CodeSentTo"] @_email
                    </MudText>
                    <label class="pa-field-label">@L["Code.Placeholder"]</label>
                    <input class="pa-input" type="text" @bind="_codeInput" maxlength="6" autocomplete="one-time-code" />

                    <button class="pa-submit" type="submit" disabled="@_isLoading">
                        @(_isLoading ? L["Common.Sending"] : L["Code.Verify"])
                    </button>

                    <div class="mt-2">
                        <MudLink @onclick="ResendAsync" Style="cursor:pointer;">@L["Code.Resend"]</MudLink>
                    </div>
                }
            </form>

            <div class="mt-4">
                <MudLink Href="/login">@L["Register.AlreadyHaveAccount"]</MudLink>
            </div>
        }
    </MudPaper>
</div>

@code {
    private string _displayName = string.Empty;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _passwordConfirm = string.Empty;
    private string _codeInput = string.Empty;
    private string? _error;
    private bool _success;
    private bool _isLoading;
    private bool _codeSent;

    private async Task SubmitAsync()
    {
        _error = null;
        _isLoading = true;

        try
        {
            if (!_codeSent)
                await SendCodeAsync();
            else
                await ValidateCodeAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SendCodeAsync()
    {
        if (string.IsNullOrWhiteSpace(_displayName) || string.IsNullOrWhiteSpace(_email) ||
            string.IsNullOrWhiteSpace(_password) || string.IsNullOrWhiteSpace(_passwordConfirm))
        {
            _error = L["ChangePassword.FillAll"];
            return;
        }

        if (_password != _passwordConfirm)
        {
            _error = L["ChangePassword.Mismatch"];
            return;
        }

        var exists = await UserService.EmailExistsAsync(_email);
        if (exists)
        {
            _error = L["Register.EmailTaken"];
            return;
        }

        var code = CodeService.GenerateCode(_email);
        try
        {
            await EnvoyerCodeAsync(_email, code);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[Register] Échec envoi code : {ex.Message}");
            _error = L["ChangePassword.Error"];
            return;
        }
        _codeSent = true;
    }

    private async Task ValidateCodeAsync()
    {
        try
        {
            CodeService.CheckCode(_email, _codeInput);
        }
        catch (BusinessException ex)
        {
            _error = L[ex.Key];
            return;
        }

        try
        {
            var language = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
            await UserService.RegisterAsync(_email, _password, _displayName, language);
        }
        catch (BusinessException ex)
        {
            _error = L[ex.Key];
            return;
        }

        try
        {
            var language = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
            await EnvoyerBienvenueAsync(_email, _displayName, language);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[Register] Échec email bienvenue : {ex.Message}");
        }

        _success = true;
    }

    private async Task ResendAsync()
    {
        _error = null;
        _codeInput = string.Empty;
        var code = CodeService.GenerateCode(_email);
        try
        {
            await EnvoyerCodeAsync(_email, code);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[Register] Échec renvoi code : {ex.Message}");
            _error = L["ChangePassword.Error"];
        }
    }

    private async Task EnvoyerBienvenueAsync(string email, string displayName, string language)
    {
        var template = await TemplateService.GetAsync("welcome", language);

        string subject;
        string htmlBody;
        if (template != null)
        {
            subject = template.Subject;
            htmlBody = Regex.Replace(template.Html, @"\{\{\s*\.?DisplayName\s*\}\}", displayName);
        }
        else
        {
            subject = language == "en" ? "Welcome!" : (language == "es" ? "¡Bienvenido!" : "Bienvenue !");
            htmlBody = $"<p>Bonjour <strong>{displayName}</strong>,</p><p>Votre compte a été créé avec succès. Bienvenue !</p>";
        }

        await EmailService.EnvoyerEmailAsync(email, subject, htmlBody);
    }

    private async Task EnvoyerCodeAsync(string email, string code)
    {
        var language = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        var template = await TemplateService.GetAsync("confirm_signup", language);

        string subject;
        string htmlBody;
        if (template != null)
        {
            subject = template.Subject;
            htmlBody = Regex.Replace(template.Html, @"\{\{\s*\.?Code\s*\}\}", code);
        }
        else
        {
            subject = "Votre code de confirmation";
            htmlBody = $"<p>Votre code de confirmation : <strong>{code}</strong> (valable 20 minutes).</p>";
        }

        await EmailService.EnvoyerEmailAsync(email, subject, htmlBody);
    }
}
