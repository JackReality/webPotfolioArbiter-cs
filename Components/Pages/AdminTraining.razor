@page "/admin/trainings"
@attribute [Authorize(Roles = "admin")]
@inject IStringLocalizer<SharedResource> L
@inject TrainingService TrainingService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Admin - Formations</PageTitle>

<div class="pa-page" style="max-width:900px;">
    <MudPaper Class="pa-6" Elevation="0" Style="background:#141414;">
        <MudText Typo="Typo.h4" GutterBottom="true">Formations</MudText>

        @* ===== Liste des formations existantes ===== *@
        @if (!_loaded)
        {
            <MudProgressLinear Color="Color.Info" Indeterminate="true" />
        }
        else if (_trainings.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">Aucune formation pour l'instant.</MudAlert>
        }
        else
        {
            <MudTable Items="_trainings" Hover="true" Dense="true" Class="mb-6">
                <HeaderContent>
                    <MudTh>Titre</MudTh>
                    <MudTh>Langue</MudTh>
                    <MudTh>Stripe Price ID</MudTh>
                    <MudTh>Créée le</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Titre">@context.Title</MudTd>
                    <MudTd DataLabel="Langue">@context.Language.ToUpper()</MudTd>
                    <MudTd DataLabel="Stripe Price ID">
                        @(string.IsNullOrWhiteSpace(context.StripePriceId) ? "—" : context.StripePriceId)
                    </MudTd>
                    <MudTd DataLabel="Créée le">@context.CreatedAt.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="() => Editer(context)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="() => SupprimerAsync(context)" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }

        <MudDivider Class="my-4" />

        @* ===== Formulaire d'ajout / d'édition (réutilisé) ===== *@
        <MudText Typo="Typo.h6" GutterBottom="true">
            @(_editingId is null ? "Ajouter une formation" : "Modifier la formation")
        </MudText>

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
        }

        <label class="pa-field-label">Titre *</label>
        <input class="pa-input" @bind="_title" />

        <label class="pa-field-label mt-4">Langue *</label>
        <MudSelect @bind-Value="_language" Dense="true" Variant="Variant.Outlined" Class="mb-2">
            <MudSelectItem Value="@("fr")">Français</MudSelectItem>
            <MudSelectItem Value="@("en")">English</MudSelectItem>
            <MudSelectItem Value="@("es")">Español</MudSelectItem>
        </MudSelect>

        <label class="pa-field-label mt-4">Description (HTML) *</label>
        <textarea class="pa-textarea" rows="8" @bind="_descriptionHtml"></textarea>

        <label class="pa-field-label mt-4">Stripe Product ID</label>
        <input class="pa-input" @bind="_stripeProductId" placeholder="prod_..." />

        <label class="pa-field-label mt-4">Stripe Price ID</label>
        <input class="pa-input" @bind="_stripePriceId" placeholder="price_..." />

        <label class="pa-field-label mt-4">Email de confirmation après achat (HTML)</label>
        <textarea class="pa-textarea" rows="6" @bind="_confirmationEmailHtml"></textarea>

        <div class="mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="EnregistrerAsync">
                @(_editingId is null ? "Ajouter" : "Enregistrer")
            </MudButton>
            @if (_editingId is not null)
            {
                <MudButton Variant="Variant.Outlined" Class="ml-2" OnClick="AnnulerEdition">
                    Annuler
                </MudButton>
            }
        </div>

        <MudDivider Class="my-6" />

        <MudButton Href="/admin-dashboard"
                   Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.ArrowBack">
            Retour au Dashboard
        </MudButton>
    </MudPaper>
</div>

@code {
    private bool _loaded;
    private List<Models.Training> _trainings = new();
    private string? _error;

    // Champs du formulaire (réutilisé pour l'ajout ET l'édition).
    private ulong? _editingId;   // null = mode ajout ; sinon = id de la formation éditée
    private string _title = string.Empty;
    private string _language = "fr";
    private string _descriptionHtml = string.Empty;
    private string _stripeProductId = string.Empty;
    private string _stripePriceId = string.Empty;
    private string _confirmationEmailHtml = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await ChargerAsync();
    }

    private async Task ChargerAsync()
    {
        _trainings = await TrainingService.GetAllAsync();
        _loaded = true;
    }

    /// <summary>Charge une formation dans le formulaire et bascule en mode édition.</summary>
    private void Editer(Models.Training training)
    {
        _error = null;
        _editingId = training.Id;
        _title = training.Title;
        _language = training.Language;
        _descriptionHtml = training.DescriptionHtml;
        _stripeProductId = training.StripeProductId ?? string.Empty;
        _stripePriceId = training.StripePriceId ?? string.Empty;
        _confirmationEmailHtml = training.ConfirmationEmailHtml ?? string.Empty;
    }

    /// <summary>Quitte le mode édition et vide le formulaire (retour en mode ajout).</summary>
    private void AnnulerEdition() => ReinitialiserFormulaire();

    private void ReinitialiserFormulaire()
    {
        _editingId = null;
        _title = _descriptionHtml = _stripeProductId = _stripePriceId = _confirmationEmailHtml = string.Empty;
        _language = "fr";
        _error = null;
    }

    /// <summary>Enregistre le formulaire : création si mode ajout, sinon mise à jour.</summary>
    private async Task EnregistrerAsync()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_title) || string.IsNullOrWhiteSpace(_descriptionHtml))
        {
            _error = "Le titre et la description sont obligatoires.";
            return;
        }

        var productId = string.IsNullOrWhiteSpace(_stripeProductId) ? null : _stripeProductId.Trim();
        var priceId = string.IsNullOrWhiteSpace(_stripePriceId) ? null : _stripePriceId.Trim();
        var confirmationEmail = string.IsNullOrWhiteSpace(_confirmationEmailHtml) ? null : _confirmationEmailHtml;

        try
        {
            if (_editingId is null)
            {
                await TrainingService.CreerAsync(
                    _title.Trim(), _language, _descriptionHtml, productId, priceId, confirmationEmail);
                Snackbar.Add("Formation ajoutée.", Severity.Success);
            }
            else
            {
                await TrainingService.UpdateAsync(
                    _editingId.Value, _title.Trim(), _language, _descriptionHtml, productId, priceId, confirmationEmail);
                Snackbar.Add("Formation modifiée.", Severity.Success);
            }

            ReinitialiserFormulaire();
            await ChargerAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SupprimerAsync(Models.Training training)
    {
        var ok = await DialogService.ShowMessageBoxAsync(
            "Confirmer la suppression",
            $"Supprimer la formation « {training.Title} » ?",
            yesText: "Supprimer", cancelText: "Annuler");

        if (ok != true)
            return;

        await TrainingService.SupprimerAsync(training.Id);
        Snackbar.Add("Formation supprimée.", Severity.Success);
        await ChargerAsync();
    }
}
