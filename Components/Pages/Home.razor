                <div class="pa-underline"></div>
                <div class="pa-body">
                    <h3 class="pa-subtitle">@L["Home.S3.Sub1.Title"]</h3>
                    <p class="pa-body">@L["Home.S3.Sub1.Body"]</p>
                    <h3 class="pa-subtitle">@L["Home.S3.Sub2.Title"]</h3>
                    <p class="pa-body">@L["Home.S3.Sub2.Body"]</p>
                    <h3 class="pa-subtitle">@L["Home.S3.Sub3.Title"]</h3>
                    <p class="pa-body">@L["Home.S3.Sub3.Body"]</p>
                </div>
            </div>
            <div class="pa-shot-wrap">
                <img src="images/strategy-site.png" alt="@L["Home.S3.Title"]" class="pa-shot" />
            </div>
        </div>
