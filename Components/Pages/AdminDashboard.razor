@page "/admin-dashboard"
@attribute [Authorize(Roles = "admin")]
@inject IStringLocalizer<SharedResource> L
@inject NavigationManager Nav

<PageTitle>Admin - Dashboard</PageTitle>

<div class="pa-page" style="max-width:600px;">
    <MudPaper Class="pa-6" Elevation="0" Style="background:#141414;">
        <MudText Typo="Typo.h4" GutterBottom="true">Admin Dashboard</MudText>

        <MudText Class="mb-6">Gestion de l'administration du site.</MudText>

        <MudButton Href="/admin/email-templates"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   FullWidth="true"
                   EndIcon="@Icons.Material.Filled.Email"
                   Class="mb-4">
            Modifier les templates d'emails
        </MudButton>

        <MudButton Href="/admin/users"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   FullWidth="true"
                   EndIcon="@Icons.Material.Filled.People"
                   Class="mb-4">
            Gérer les utilisateurs
        </MudButton>

        <MudButton Href="/admin/trainings"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   FullWidth="true"
                   EndIcon="@Icons.Material.Filled.School">
            Gérer les formations
        </MudButton>
    </MudPaper>
</div>
