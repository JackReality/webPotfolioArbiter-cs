@page "/acces-reserve"
@* Affichée soit par Routes.razor (rôle insuffisant), soit par redirection HTTP
   (AccessDeniedPath du cookie) quand un user connecté n'a pas le bon rôle. *@
@inject IStringLocalizer<SharedResource> L

<div class="pa-page">
    <MudText Typo="Typo.h3" GutterBottom="true">@L["AccesReserve.Title"]</MudText>
    <MudText Class="mb-6" Style="opacity:.85;">@L["AccesReserve.Body"]</MudText>
    <MudButton Href="/formation" Variant="Variant.Filled" Color="Color.Primary">@L["AccesReserve.Cta"]</MudButton>
</div>
