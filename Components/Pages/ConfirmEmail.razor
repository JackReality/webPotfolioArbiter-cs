@page "/confirm-email"
@inject IStringLocalizer<SharedResource> L
@inject TokenService TokenService
@inject UserService UserService

<PageTitle>@L["ConfirmEmail.Title"]</PageTitle>

<div class="pa-page" style="max-width:460px;">
    <MudPaper Class="pa-6" Elevation="0" Style="background:#141414;">
        <MudText Typo="Typo.h4" GutterBottom="true">@L["ConfirmEmail.Title"]</MudText>

        @if (_loading)
        {
            <MudProgressCircular Indeterminate="true" Class="mt-4" />
        }
        else if (_success)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">@L["ConfirmEmail.Success"]</MudAlert>
            <div class="mt-4">
                <MudLink Href="/login">@L["Common.BackToLogin"]</MudLink>
            </div>
        }
        else
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@L["ConfirmEmail.InvalidToken"]</MudAlert>
            <div class="mt-4">
                <MudLink Href="/register">@L["ConfirmEmail.TryAgain"]</MudLink>
            </div>
        }
    </MudPaper>
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private bool _loading = true;
    private bool _success;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            _loading = false;
            return;
        }

        var userId = await TokenService.GetUserIdFromTokenAsync(Token, "confirm_signup");
        if (userId is null)
        {
            _loading = false;
            return;
        }

        await UserService.ConfirmEmailAsync(userId.Value);
        await TokenService.SupprimerJetonAsync(Token);

        _success = true;
        _loading = false;
    }
}
