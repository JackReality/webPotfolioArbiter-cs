@page "/forgot-password"
@inject IStringLocalizer<SharedResource> L
@inject UserService UserService
@inject TokenService TokenService
@inject EmailService EmailService
@inject EmailTemplateService TemplateService
@inject NavigationManager Nav
@using DotNetEnv
@using System.Text.RegularExpressions

<PageTitle>@L["ForgotPassword.Title"]</PageTitle>

<div class="pa-page" style="max-width:460px;">
    <MudPaper Class="pa-6" Elevation="0" Style="background:#141414;">
        <MudText Typo="Typo.h4" GutterBottom="true">@L["ForgotPassword.Title"]</MudText>
        <MudText Class="mb-4" Style="opacity:.8;">@L["ForgotPassword.Subtitle"]</MudText>

        @if (_success)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">@L["ForgotPassword.SuccessMessage"]</MudAlert>
            <div class="mt-4">
                <MudLink Href="/login">@L["Common.BackToLogin"]</MudLink>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
            }

            <form @onsubmit="RequestResetAsync" @onsubmit:preventDefault>
                <label class="pa-field-label">@L["Auth.Email"]</label>
                <input class="pa-input" type="email" @bind="_email" required autocomplete="email" />

                <button class="pa-submit" type="submit" Disabled="@_isLoading">
                    @(_isLoading ? L["Common.Sending"] : L["ForgotPassword.Submit"])
                </button>
            </form>

            <div class="mt-4">
                <MudLink Href="/login">@L["Common.Back"]</MudLink>
            </div>
        }
    </MudPaper>
</div>

@code {
    private string _email = string.Empty;
    private string? _error;
    private bool _success;
    private bool _isLoading;

    private async Task RequestResetAsync()
    {
        _error = null;
        _success = false;
        _isLoading = true;

        if (string.IsNullOrWhiteSpace(_email))
        {
            _error = L["ChangePassword.FillAll"];
            _isLoading = false;
            return;
        }

        try
        {
            // On cherche l'utilisateur par email
            var user = await UserService.GetByEmailAsync(_email);

            // Pour des raisons de sécurité, on affiche TOUJOURS le même message de
            // succès, même si l'email n'existe pas, pour éviter l'énumération des comptes.
            if (user != null)
            {
                // Générer un token de récupération (valide 1 heure)
                var token = await TokenService.GenererJetonsAsync(user.Id, "recovery", dureeHeures: 1);

                // Construire le lien de réinitialisation à partir de BASE_URL dans .env
                var baseUrl = Env.GetString("BASE_URL", "http://localhost:5252").TrimEnd('/');
                var resetLink = $"{baseUrl}/reset-password?token={token}";

                // Récupérer le template "recovery" éditable par l'admin, dans la langue
                // de l'utilisateur (repli FR si absente). La variable {{ .ConfirmationURL }}
                // présente dans le template est remplacée par le lien réel.
                var language = string.IsNullOrWhiteSpace(user.Language) ? "fr" : user.Language;
                var template = await TemplateService.GetAsync("recovery", language);

                string subject;
                string htmlBody;
                if (template != null)
                {
                    subject = template.Subject;
                    htmlBody = Regex.Replace(
                        template.Html,
                        @"\{\{\s*\.?ConfirmationURL\s*\}\}",
                        resetLink);
                }
                else
                {
                    // Repli minimal si aucun template n'est présent en base.
                    subject = "Réinitialisation de votre mot de passe";
                    htmlBody = $@"<p>Bonjour {user.DisplayName},</p>
                        <p><a href=""{resetLink}"">Réinitialiser mon mot de passe</a> (lien valide 1 heure).</p>";
                }

                // L'échec d'envoi ne doit JAMAIS être révélé à l'utilisateur (sinon on
                // trahit l'existence du compte). On loggue côté serveur uniquement.
                try
                {
                    await EmailService.EnvoyerEmailAsync(user.Email, subject, htmlBody);
                }
                catch (Exception ex)
                {
                    // TODO: brancher le mailErrorSend() global (voir STATUS.md).
                    Console.Error.WriteLine($"[Reset] Échec d'envoi de l'email de récupération : {ex}");
                }
            }

            _success = true;
        }
        catch (Exception ex)
        {
            // Erreur inattendue (ex. base de données indisponible) : message générique,
            // jamais le détail technique.
            Console.Error.WriteLine($"[Reset] Erreur inattendue : {ex}");
            _error = L["ChangePassword.Error"];
        }
        finally
        {
            _isLoading = false;
        }
    }
}
