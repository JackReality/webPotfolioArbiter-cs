@page "/catalog"
@page "/trainings"
@* Page PUBLIQUE : tout le monde peut consulter le catalogue. *@
@using System.Globalization
@using System.Security.Claims
@using Portfolio.Exceptions
@inject IStringLocalizer<SharedResource> L
@inject TrainingService TrainingService
@inject StripeService StripeService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Catalogue</PageTitle>

<div class="pa-page" style="max-width:800px;">
    <MudText Typo="Typo.h3" GutterBottom="true">Catalogue</MudText>

    @if (!_loaded)
    {
        <MudProgressLinear Color="Color.Info" Indeterminate="true" />
    }
    else if (_trainings.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">@L["Catalog.Empty"]</MudAlert>
        <MudButton Href="/contact"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Email">
            @L["Nav.Contact"]
        </MudButton>
    }
    else
    {
        @for (var i = 0; i < _trainings.Count; i++)
        {
            var training = _trainings[i];

            @* Trait de séparation entre les formations (sauf avant la première). *@
            if (i > 0)
            {
                <MudDivider Class="my-8" />
            }

            <div class="mb-4">
                <MudText Typo="Typo.h4" GutterBottom="true">@training.Title</MudText>

                @* Bouton Acheter EN HAUT *@
                <div class="my-4">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.ShoppingCart"
                               OnClick="() => AcheterAsync(training)">
                        Acheter
                    </MudButton>
                </div>

                @* Description HTML (rendue telle quelle) *@
                <div class="pa-formation-desc">
                    @((MarkupString)training.DescriptionHtml)
                </div>

                @* Bouton Acheter EN BAS *@
                <div class="my-4">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.ShoppingCart"
                               OnClick="() => AcheterAsync(training)">
                        Acheter
                    </MudButton>
                </div>
            </div>
        }
    }
</div>

@code {
    private bool _loaded;
    private List<Models.Training> _trainings = new();

    protected override async Task OnInitializedAsync()
    {
        // On n'affiche que les formations de la langue courante (une formation par langue).
        var language = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        _trainings = await TrainingService.GetByLanguageAsync(language);
        _loaded = true;
    }

    private async Task AcheterAsync(Models.Training training)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (!user.Identity?.IsAuthenticated ?? true)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        var userId = ulong.Parse(user.FindFirstValue(ClaimTypes.NameIdentifier)!);
        var baseUrl = Navigation.BaseUri.TrimEnd('/');

        try
        {
            var stripeUrl = await StripeService.CreateCheckoutSessionAsync(
                training,
                userId,
                successUrl: $"{baseUrl}/stripe-ok?session_id={{CHECKOUT_SESSION_ID}}",
                cancelUrl:  $"{baseUrl}/catalog");

            Navigation.NavigateTo(stripeUrl, forceLoad: true);
        }
        catch (BusinessException ex)
        {
            Snackbar.Add(L[ex.Key], Severity.Warning);
        }
    }
}
