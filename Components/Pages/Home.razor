@page "/"
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Home.Hero.Title"]</PageTitle>

@* ===================== SECTION 1 : Hero + "Bien plus qu'un tableur" ===================== *@
<section class="pa-section" style="background-image:url('images/cahier.jpg')">
    <div class="pa-section__inner">
        <div class="pa-card pa-hero-card">
            <p class="pa-kicker">@L["Home.Hero.Kicker"]</p>
            <div class="pa-underline"></div>
            <h1 class="pa-hero-title">@L["Home.Hero.Title"]</h1>
            <p class="pa-hero-sub">@L["Home.Hero.Subtitle"]</p>
        </div>

        <div class="pa-grid">
            <div class="pa-card">
                <h2 class="pa-card__title">@L["Home.S1.Title"]</h2>
                <div class="pa-underline"></div>
                <p class="pa-body">@L["Home.S1.Body"]</p>
            </div>
            <div class="pa-shot-wrap">
                <img src="images/ticker-site.png" alt="@L["Home.S1.Title"]" class="pa-shot" />
            </div>
        </div>
    </div>
</section>

<div class="pa-separator"><div class="pa-separator__line"></div></div>

@* ===================== SECTION 2 : Une position (image gauche) ===================== *@
<section class="pa-section" style="background-image:url('images/position-book.png')">
    <div class="pa-section__inner">
        <div class="pa-grid">
            <div class="pa-shot-wrap">
                <img src="images/position-site.png" alt="@L["Home.S2.Title"]" class="pa-shot" />
