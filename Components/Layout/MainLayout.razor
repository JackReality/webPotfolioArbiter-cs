@inherits LayoutComponentBase
@using System.Globalization
@using System.Security.Claims
@inject NavigationManager Nav
@inject IWebHostEnvironment Env
@inject IStringLocalizer<SharedResource> L
@inject UserService UserService
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<!-- Thème : fond noir, accent bordeaux #9d1f45, toujours en mode sombre -->
<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <!-- ===================== EN-TÊTE (sur toutes les pages) ===================== -->
    <MudAppBar Elevation="0" Style="background:#000;" Dense="false">
        <MudLink Href="/">
            <img src="images/logo-white.png" alt="@L["Site.Name"]" class="pa-logo" />
        </MudLink>

        <MudSpacer />

        <nav class="d-none d-md-flex">
            <a href="/" class="pa-navlink @Active("")">@L["Nav.Home"]</a>
            <a href="/download" class="pa-navlink @Active("download")">@L["Nav.Download"]</a>
            <a href="/training" class="pa-navlink @Active("training")">@L["Nav.Training"]</a>
        </nav>

        <MudSpacer />

        <div class="pa-lang me-4">
            @* On garde le href (repli en SSR / si le circuit n'est pas connecté), mais
               on intercepte le clic pour forcer un VRAI rechargement complet
               (NavigateTo forceLoad:true) : le routeur Blazor n'intercepte donc plus
               la navigation vers l'endpoint /Culture/Set, et la langue s'applique
               toujours à tout le site. *@
            <a href="@CultureHref("fr")" @onclick:preventDefault @onclick='() => SetCulture("fr")' class="@LangActive("fr")">FR</a>
            <span class="sep">|</span>
            <a href="@CultureHref("en")" @onclick:preventDefault @onclick='() => SetCulture("en")' class="@LangActive("en")">EN</a>
            <span class="sep">|</span>
            <a href="@CultureHref("es")" @onclick:preventDefault @onclick='() => SetCulture("es")' class="@LangActive("es")">ES</a>
        </div>
        <AuthorizeView>
            <Authorized Context="authContext">
                @* Picto utilisateur : avatar si photo, icône par défaut sinon *@
                <a href="/profile" class="pa-user-avatar" title="@L["Profile.Title"]">
                    @if (!string.IsNullOrEmpty(_userAvatarUrl))
                    {
                        <img src="@_userAvatarUrl" alt="Avatar" class="pa-avatar-img" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Class="pa-avatar-icon" />
                    }
                </a>
                <form method="post" action="/auth/logout" data-enhance="false" style="display:inline;">
                    <AntiforgeryToken />
                    <button type="submit" class="pa-navlink"
                            style="background:none; border:none; cursor:pointer; font:inherit;">
                        @L["Nav.Logout"]
                    </button>
                </form>
            </Authorized>
            <NotAuthorized>
                <a href="/login" class="pa-navlink">@L["Nav.Login"]</a>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <!-- ===================== CONTENU + FRONTIÈRE D'ERREUR ===================== -->
    <MudMainContent>
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="ma-4">
                    <strong>Une erreur technique est survenue.</strong>
                    Nous avons été notifiés. Réessayez ou revenez à l'accueil.
                </MudAlert>
                @if (Env.IsDevelopment())   // détails affichés UNIQUEMENT en développement
                {
                    <pre style="background:#eedddd; color:#000; padding:10px; font-size:12px; overflow:auto;">
@ex.Message

@ex.StackTrace
                    </pre>
                }
            </ErrorContent>
        </ErrorBoundary>

        <!-- ===================== PIED DE PAGE (sur toutes les pages) ===================== -->
        <footer class="pa-footer">
            <div class="pa-footer__inner">
                <div class="pa-footer__left">
                    <img src="images/logo-white.png" alt="@L["Site.Name"]" class="pa-logo" style="opacity:.9;" />
                    <div>
                        <p style="margin:0 0 12px;">© 2026 @L["Site.Name"]. @L["Footer.Rights"]</p>
                        <a href="/legal">@L["Footer.Legal"]</a>
                    </div>
                </div>
                <a href="https://www.youtube.com/@@portfolioarbiter" target="_blank" rel="noopener noreferrer"
                   aria-label="YouTube" class="pa-youtube">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"></path>
                        <path d="m10 15 5-3-5-3z"></path>
                    </svg>
                </a>
            </div>
        </footer>
    </MudMainContent>
</MudLayout>

@code {
    private ErrorBoundary? _errorBoundary;
    private string? _userAvatarUrl;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        await LoadUserAvatarAsync();
    }

    /// <summary>Charge l'avatar de l'utilisateur connecté (via le cookie d'authentification).</summary>
    private async Task LoadUserAvatarAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var idClaim = user.FindFirst(ClaimTypes.NameIdentifier);
        if (idClaim != null && ulong.TryParse(idClaim.Value, out var userId))
        {
            var dbUser = await UserService.GetByIdAsync(userId);
            _userAvatarUrl = dbUser?.AvatarUrl;
            StateHasChanged();
        }
    }

    // Thème MudBlazor : palette sombre + couleur primaire bordeaux.
    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark()
        {
            Primary = "#9d1f45",
            Black = "#000000",
            Background = "#0a0a0a",
            Surface = "#141414",
            AppbarBackground = "#000000",
            AppbarText = "#ffffff",
            DrawerBackground = "#000000",
            TextPrimary = "#ffffff"
        }
    };

    // Désactive l'erreur si elle existe lors de changement de la page
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
        => _errorBoundary?.Recover();

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;

    // --- Aides pour le menu et le sélecteur de langue ---

    // Classe "active" si on est sur la page donnée (chemin relatif).
    private string Active(string relativePath)
        => string.Equals(Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].TrimEnd('/'),
                          relativePath, StringComparison.OrdinalIgnoreCase)
           ? "active" : "";

    // Classe "active" pour la langue actuellement affichée.
    private string LangActive(string culture)
        => CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == culture ? "active" : "";

    // Construit le lien qui change la langue puis revient sur la page courante.
    private string CultureHref(string culture)
    {
        var redirect = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        return $"/Culture/Set?culture={culture}&redirectUri={Uri.EscapeDataString(redirect)}";
    }

    // Change la langue avec un VRAI rechargement (forceLoad) pour que le routeur
    // Blazor n'intercepte pas la navigation vers l'endpoint /Culture/Set.
    private void SetCulture(string culture)
        => Nav.NavigateTo(CultureHref(culture), forceLoad: true);
}
